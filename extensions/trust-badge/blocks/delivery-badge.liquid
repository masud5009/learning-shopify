{% assign app_settings = shop.metafields.trust_badge.settings.value %}

{% if app_settings.enabled %}
  <div class="delivery-badge" style="background: {{ app_settings.bgColor }};">

    {% if app_settings.heading != blank %}
      <h3>{{ app_settings.heading }}</h3>
    {% endif %}

    {% if product and product.metafields.custom.trust_badge_message != blank %}
      <p>{{ product.metafields.custom.trust_badge_message }}</p>
    {% elsif app_settings.message != blank %}
      <p>{{ app_settings.message }}</p>
    {% endif %}

  </div>
{% endif %}

{% schema %}
{
  "name": "Trust Badge",
  "target": "section",
  "stylesheet": "delivery-badge.css",
  "settings": []
}
{% endschema %}
