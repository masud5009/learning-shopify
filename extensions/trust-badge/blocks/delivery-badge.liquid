<div class="delivery-badge" style="background: {{ block.settings.bg_color }};">
  {% if block.settings.heading != blank %}
    <h3>{{ block.settings.heading }}</h3>
  {% endif %}

  {% if block.settings.line_1 != blank %}
    <p>{{ block.settings.line_1 }}</p>
  {% endif %}

  {% if block.settings.line_2 != blank %}
    <p>{{ block.settings.line_2 }}</p>
  {% endif %}

  {% if block.settings.line_3 != blank %}
    <p>{{ block.settings.line_3 }}</p>
  {% endif %}
</div>

{% schema %}
{
  "name": "Trust Badge",
  "target": "section",
  "stylesheet": "delivery-badge.css",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why shop with us?"
    },
    {
      "type": "text",
      "id": "line_1",
      "label": "Line 1",
      "default": "🚚 Free delivery available"
    },
    {
      "type": "text",
      "id": "line_2",
      "label": "Line 2",
      "default": "🔒 Secure checkout"
    },
    {
      "type": "text",
      "id": "line_3",
      "label": "Line 3",
      "default": "↩️ 7-day return"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    }
  ]
}
{% endschema %}
